<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tickets de Carga — Bimbo</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
/* ══════════════════════════════════════════
   PANTALLA
══════════════════════════════════════════ */
:root {
  --azul:#0055A4; --azul-oscuro:#003D7A;
  --rojo:#E30613; --amarillo:#FFD500;
  --gris-claro:#f4f6fa; --gris-borde:#d0d7e3; --texto:#1a1f2e;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--gris-claro);color:var(--texto);min-height:100vh;}

.topbar{background:var(--azul-oscuro);padding:13px 24px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 10px rgba(0,0,0,.2);}
.topbar .brand{font-family:'Syne',sans-serif;font-weight:800;font-size:1.15rem;color:#fff;}
.topbar .brand span{color:var(--amarillo);}
.topbar .version{font-size:.7rem;color:rgba(255,255,255,.4);}

.layout{display:grid;grid-template-columns:300px 1fr;min-height:calc(100vh - 50px);}

/* ── Sidebar ── */
.sidebar{background:#fff;border-right:1px solid var(--gris-borde);padding:20px 16px;overflow-y:auto;display:flex;flex-direction:column;gap:14px;}
.sidebar h2{font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;color:var(--azul-oscuro);padding-bottom:10px;border-bottom:2px solid var(--amarillo);}

.upload-zone{border:2px dashed var(--gris-borde);border-radius:9px;padding:18px 12px;text-align:center;cursor:pointer;transition:.2s;}
.upload-zone:hover{border-color:var(--azul);background:#eef3fb;}
.upload-zone .icon{font-size:1.8rem;margin-bottom:5px;}
.upload-zone p{font-size:.78rem;color:#6b7280;}
.upload-zone p strong{color:var(--azul);}
.upload-zone.loaded{border-color:#16a34a;background:#f0fdf4;cursor:default;}
.upload-zone.loaded p,.upload-zone.loaded p strong{color:#16a34a;}
#file-input{display:none;}

.field label{display:block;font-size:.67rem;font-weight:600;color:#6b7280;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px;}
.field select,.field input{width:100%;padding:8px 10px;border:1.5px solid var(--gris-borde);border-radius:6px;font-family:'DM Sans',sans-serif;font-size:.85rem;color:var(--texto);background:var(--gris-claro);transition:.2s;}
.field select:focus,.field input:focus{outline:none;border-color:var(--azul);background:#fff;}
select:disabled{opacity:.45;}

.rango-grid{display:grid;grid-template-columns:1fr 18px 1fr;gap:5px;align-items:center;}
.rango-grid span{text-align:center;font-size:.75rem;color:#9ca3af;}

.rutas-badge{font-size:.7rem;margin-top:5px;display:none;padding:4px 8px;border-radius:4px;background:#eef3fb;color:var(--azul);}
.rutas-badge.warn{background:#fff1f1;color:var(--rojo);}

.info-box{background:#eef3fb;border-left:3px solid var(--azul);border-radius:0 5px 5px 0;padding:8px 10px;font-size:.75rem;color:var(--azul-oscuro);display:none;}
.info-box b{display:block;margin-bottom:2px;font-size:.78rem;}

.btn-gen{width:100%;padding:12px;background:var(--azul);color:#fff;border:none;border-radius:7px;font-family:'Syne',sans-serif;font-weight:700;font-size:.9rem;cursor:pointer;transition:.2s;}
.btn-gen:hover:not(:disabled){background:var(--azul-oscuro);}
.btn-gen:disabled{background:#9ca3af;cursor:not-allowed;}

.btn-print-all{width:100%;padding:11px;background:var(--rojo);color:#fff;border:none;border-radius:7px;font-family:'Syne',sans-serif;font-weight:700;font-size:.88rem;cursor:pointer;transition:.2s;display:none;}
.btn-print-all:hover{background:#c0050f;}

/* ── Area de preview ── */
.preview-area{padding:24px;overflow-y:auto;}
.preview-title{font-family:'Syne',sans-serif;font-weight:700;font-size:.85rem;color:#6b7280;margin-bottom:16px;display:none;}

.tickets-grid{display:flex;flex-wrap:wrap;gap:20px;justify-content:flex-start;}

/* ── Tarjeta de ticket (pantalla) ── */
.ticket-card{background:#fff;border:1.5px solid var(--gris-borde);border-radius:8px;overflow:hidden;box-shadow:0 3px 16px rgba(0,61,122,.08);width:300px;flex-shrink:0;}
.ticket-card .card-controls{background:#f8f9fb;border-top:1px solid var(--gris-borde);padding:8px 12px;display:flex;gap:8px;}
.card-controls .btn-one{flex:1;padding:6px;background:var(--azul);color:#fff;border:none;border-radius:5px;font-size:.75rem;font-weight:600;cursor:pointer;font-family:'Syne',sans-serif;}
.card-controls .btn-one:hover{background:var(--azul-oscuro);}

.placeholder-big{padding:60px 20px;text-align:center;color:#9ca3af;font-size:.85rem;line-height:2;}
.placeholder-big span{font-size:2.5rem;display:block;margin-bottom:10px;}

/* ══════════════════════════════════════════
   TICKET TÉRMICO 80mm
   Aplica dentro .thermal-ticket (pantalla y print)
══════════════════════════════════════════ */
.thermal-ticket{
  font-family:'Courier New',Courier,monospace;
  font-size:11px;
  color:#000;
  background:#fff;
  width:100%;
  padding:8px 6px;
}

.th-header{text-align:center;border-bottom:1px dashed #000;padding-bottom:6px;margin-bottom:6px;}
.th-title{font-size:13px;font-weight:bold;letter-spacing:.5px;}
.th-sucursal{font-size:10px;margin-top:1px;}
.th-meta{font-size:9px;margin-top:3px;display:flex;justify-content:space-between;}
.th-ruta{font-size:12px;font-weight:bold;margin-top:4px;}

.th-section{margin-bottom:4px;}
.th-sec-title{
  font-weight:bold;
  font-size:10px;
  text-transform:uppercase;
  letter-spacing:.5px;
  border-top:1px solid #000;
  border-bottom:1px solid #000;
  padding:2px 0;
  margin:4px 0 2px;
}

.th-table{width:100%;border-collapse:collapse;font-size:10px;}
.th-table td{padding:1px 2px;vertical-align:top;}
.th-table td:nth-child(2),.th-table td:nth-child(3){text-align:right;white-space:nowrap;width:28px;}
.th-table tr:nth-child(even) td{background:#f5f5f5;}

.th-col-headers{display:flex;justify-content:space-between;font-size:9px;font-weight:bold;border-bottom:1px solid #ccc;padding-bottom:1px;margin-bottom:1px;}
.th-col-headers .ch-prod{flex:1;}
.th-col-headers .ch-t,.th-col-headers .ch-p{width:28px;text-align:right;}

.th-equipo{margin-top:4px;border-top:1px dashed #000;padding-top:4px;}
.th-equipo-title{font-size:9px;font-weight:bold;text-transform:uppercase;margin-bottom:2px;}
.th-eq-row{display:flex;justify-content:space-between;font-size:10px;padding:1px 0;}

.th-footer{border-top:1px dashed #000;margin-top:6px;padding-top:4px;font-size:9px;text-align:center;color:#555;}

/* ══════════════════════════════════════════
   IMPRESIÓN
══════════════════════════════════════════ */
@media print {
  body{background:#fff;}
  .topbar,.sidebar,.preview-title{display:none!important;}
  .layout{display:block;}
  .preview-area{padding:0;}
  .tickets-grid{display:block;}

  .ticket-card{
    width:80mm;
    border:none;
    border-radius:0;
    box-shadow:none;
    page-break-after:always;
    break-after:page;
  }
  .ticket-card:last-child{page-break-after:avoid;break-after:avoid;}
  .card-controls{display:none!important;}

  .thermal-ticket{
    font-size:10px;
    padding:4px 2px;
  }
  .th-title{font-size:12px;}
  .th-table{font-size:9px;}
  .th-table tr:nth-child(even) td{background:none;}
}
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">Bimbo <span>Tickets de Carga</span></div>
  <div class="version">Térmico 80mm · Un ticket por ruta</div>
</div>

<div class="layout">

  <!-- ── Sidebar ── -->
  <div class="sidebar">
    <h2>Configurar</h2>

    <div class="upload-zone" id="upload-zone" onclick="triggerUpload()">
      <div class="icon">📂</div>
      <p><strong>Haz clic aquí</strong> para subir el archivo</p>
      <p style="margin-top:3px;font-size:.7rem;">OLA_vta_DDMMMAAAA.xlsx</p>
    </div>
    <input type="file" id="file-input" accept=".xlsx,.xls">

    <div class="info-box" id="info-box">
      <b id="info-nombre">—</b>
      <span id="info-detalle">—</span>
    </div>

    <div class="field">
      <label>Fecha</label>
      <select id="sel-fecha" disabled><option>— carga el archivo —</option></select>
    </div>

    <div class="field">
      <label>Rango de rutas</label>
      <div class="rango-grid">
        <select id="sel-ini" disabled><option>—</option></select>
        <span>a</span>
        <select id="sel-fin" disabled><option>—</option></select>
      </div>
      <div class="rutas-badge" id="rutas-badge">—</div>
    </div>

    <div class="field">
      <label>Folio</label>
      <input type="text" id="f-folio" value="F1">
    </div>

    <div class="field">
      <label>Hora</label>
      <input type="time" id="f-hora">
    </div>

    <button class="btn-gen" id="btn-gen" disabled onclick="generarTodos()">⟳ Generar Tickets</button>
    <button class="btn-print-all" id="btn-print" onclick="window.print()">🖨 Imprimir Todos</button>
  </div>

  <!-- ── Vista previa ── -->
  <div class="preview-area">
    <div class="preview-title" id="preview-title">Vista previa — tickets generados</div>
    <div class="tickets-grid" id="tickets-grid">
      <div class="placeholder-big">
        <span>🗒</span>
        Sube el archivo OLA,<br>elige el rango de rutas<br>y presiona <strong>Generar Tickets</strong>
      </div>
    </div>
  </div>

</div>

<script>
/* ══ DATOS ══ */
let allData = [];

const now = new Date();
document.getElementById('f-hora').value = now.toTimeString().slice(0,5);

/* ══ CATEGORÍAS por nombre de producto ══
   Reglas simples basadas en los sufijos/palabras clave del archivo real */
const CATEGORIAS = [
  { label: 'BOLLERÍA',    test: p => /Bimbol|SuperBoll|SupeBol|MediaNoch|MediNoc|BolBrioch|BolSupAjo|BollCarl|BimParr|HotDog|SupHDog|BimbBrio|BolSup|Bollos|BimLunch/i.test(p) },
  { label: 'SALADOS',     test: p => /PBlanc|PBla|PanInt|PnArte|PanCer|MulCer|PanLin|PNatur|PanMultig|Pan12Gran|WonAjon|PMolid|Molido|Pan100pct|PInteg|PBlanco|Pan12|Tort|Tost|Reban|PanRel|HotDog|SupHDog|Bimbol.*Parr|BimbParr|BimParr|MediNoc|MediaNoch|SuperBol|SupeBol/i.test(p) && !/Dulce|Gans|Pingu|Choc|Roles|Cros|Bimbun|Dona|Concha|Panque|DuoNit|Nito|Spon|Trik|Subm|Mobi|Dalm|Bomb|Barrit|Caneli|Powder|Polvo|Favor|Mada|Man[Vu]|Colch|BraFrut|BranFrut|BFrGrn|MiPan|GalletaAve|Muffv|MiPol|Tar|Pas[tC]|Ping|ChocRole|RolloF|DuoPy|MaxC|MaxP|MaxTr|Maxit|MinBar|MiniBar|MinPing|MinGansi|MinChRol|2PackGans|Anim|LBSo|LBi|LechG|LecheN|TriGans|TuboGans|FrutSpo|MiGansi|MiPingu|GalletPing|Cors|CanapMTA|Caña/i.test(p) },
  { label: 'TÍA ROSA',    test: p => /Concha|Bigot|Bigo[Ct]|SemtPil|Cuern|MantVaini|MantNue|TiritDor|PasCua|MantNja|MantecBico|MantecaVai|MantecaNue|MadCuadr|TiraDor|Doradit|GalletaAve|Muffv|MiPol|TarPin|TarZar|TarFre|MantV.*SP|Empa[Nc]|EmpanCaj|FavNuez|FavVain|FavorVain|MagnasCPT|ManHer|ManVa|RockTir|RolesC|RolGlas|DecaRosq|Polvo.*Pane|Cors|Caña|Maria|DelicBetun|DelicBomb|DelicVain|DelicChoc|DonEsp|Donad|Donas|Doners/i.test(p) },
  { label: 'MARINELA',    test: p => /Gans[oi]|Gans50|Pingu|ChocRole|RolloFres|DuoNapol|DuoNitoSP|DuoPyP|DuoPyN|Dalmat|Bomb.*55|ChocotFre|Mobi|PastH|PastC|PastBoca|PastiOri|PayF|PingH|ChRolCe|MinGansi|MinChRol|MinPing|TriGans|TuboGans|MiGansi|MiPingu|GalletPing|2PackGans|LechGans|LecheNito|FrutSpo|Nito[1M]|SubChoSP|SubFsa|SubVai|SubmFsa|SubmVai|SubmCho/i.test(p) },
  { label: 'BIMBO DULCE', test: p => /Bimbunue|Cros[MH]|CrossCho|Panque|DuoNito|Spon[ch]|Trik|Dona[rs]|ConchVain|ConchaVai|BraFrut|BranFrut|BFrGrn|MiPanN|Mada|ManV[a6]|ManHer|Colch|MChisp|LBSo|LBi|Canelita|CaneBit|TrikBit|Lors|Reban|DelChoch|Barrit|BarFre|BarPin|BesoN|PnqctoChoco|MiBarrFre|MinBarF|MinBarP|MiniBar|PromBarr|PromPing|PromRoll|MaxC|MaxP|MaxTr|Maxit|Anim|Cors|Caña/i.test(p) },
  { label: 'GALLETAS',    test: p => /Canap|Crem.*LAR|Galeta|Gallet|Salada|Salmas|FPSalmas|STostN|Lors|Maria|Decad|MaxC|MaxP|MaxTr|Maxit|Tosta|TostClas|GallMolid|Snack/i.test(p) },
];

function categorizar(producto) {
  for (const c of CATEGORIAS) {
    if (c.test(producto)) return c.label;
  }
  return 'OTROS';
}

/* ══ UPLOAD ══ */
function triggerUpload() {
  if (!document.getElementById('upload-zone').classList.contains('loaded'))
    document.getElementById('file-input').click();
}

document.getElementById('file-input').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    const wb = XLSX.read(ev.target.result, { type:'array', cellDates:true });
    const ws = wb.Sheets[wb.SheetNames[0]];
    allData = XLSX.utils.sheet_to_json(ws, { raw:false, dateNF:'yyyy-mm-dd' });

    const zone = document.getElementById('upload-zone');
    zone.classList.add('loaded');
    zone.querySelector('p').innerHTML = `<strong>✔ ${file.name}</strong>`;
    zone.querySelector('p:last-child').textContent = `${allData.length} registros`;

    document.getElementById('info-nombre').textContent = file.name;
    document.getElementById('info-detalle').textContent = `${allData.length} filas · ${wb.SheetNames[0]}`;
    document.getElementById('info-box').style.display = 'block';

    const fechas = [...new Set(allData.map(r => (r['Fecha']||'').toString().slice(0,10)).filter(Boolean))].sort();
    const sf = document.getElementById('sel-fecha');
    sf.innerHTML = '<option value="">— fecha —</option>' + fechas.map(f=>`<option value="${f}">${fmtF(f)}</option>`).join('');
    sf.disabled = false;
    if (fechas.length === 1) { sf.value = fechas[0]; sf.dispatchEvent(new Event('change')); }
  };
  reader.readAsArrayBuffer(file);
});

/* ══ FECHA → RUTAS ══ */
document.getElementById('sel-fecha').addEventListener('change', function() {
  const fecha = this.value;
  const si = document.getElementById('sel-ini');
  const sf2 = document.getElementById('sel-fin');
  document.getElementById('btn-gen').disabled = true;
  document.getElementById('rutas-badge').style.display = 'none';
  if (!fecha) { si.innerHTML='<option>—</option>'; si.disabled=true; sf2.innerHTML='<option>—</option>'; sf2.disabled=true; return; }

  const rutas = [...new Set(allData.filter(r=>r['Fecha']&&r['Fecha'].toString().startsWith(fecha)).map(r=>r['Ruta']).filter(Boolean))].sort((a,b)=>a-b);
  const opts = rutas.map(r=>`<option value="${r}">${r}</option>`).join('');
  si.innerHTML = '<option value="">— desde —</option>' + opts;
  sf2.innerHTML = '<option value="">— hasta —</option>' + opts;
  si.disabled = false; sf2.disabled = false;
  if (rutas.length) { si.value = rutas[0]; sf2.value = rutas[rutas.length-1]; actualizarBadge(); }
});

document.getElementById('sel-ini').addEventListener('change', actualizarBadge);
document.getElementById('sel-fin').addEventListener('change', actualizarBadge);

function actualizarBadge() {
  const fecha = document.getElementById('sel-fecha').value;
  const ini = parseInt(document.getElementById('sel-ini').value);
  const fin = parseInt(document.getElementById('sel-fin').value);
  const badge = document.getElementById('rutas-badge');
  badge.style.display = 'block';
  if (!ini || !fin) { badge.textContent='Selecciona rango'; badge.className='rutas-badge warn'; document.getElementById('btn-gen').disabled=true; return; }
  const rutas = rutasEnRango(fecha, ini, fin);
  if (!rutas.length) { badge.textContent='⚠ Sin rutas en ese rango'; badge.className='rutas-badge warn'; document.getElementById('btn-gen').disabled=true; return; }
  badge.textContent = `✔ ${rutas.length} ruta${rutas.length>1?'s':''}: ${rutas.slice(0,8).join(', ')}${rutas.length>8?'…':''}`;
  badge.className = 'rutas-badge';
  document.getElementById('btn-gen').disabled = false;
}

function rutasEnRango(fecha, ini, fin) {
  return [...new Set(allData.filter(r=>r['Fecha']&&r['Fecha'].toString().startsWith(fecha)).map(r=>r['Ruta']).filter(Boolean))]
    .filter(r=>r>=ini&&r<=fin).sort((a,b)=>a-b);
}

/* ══ HELPERS ══ */
function fmtF(iso) { if(!iso)return''; const[y,m,d]=iso.split('-'); return`${d}/${m}/${y}`; }

const CONT_ORDEN = ['MTA - Media Tina Alta','MTB - Media Tina Baja','CU - Contenedor Unico','TIR - Tina Roja','CJM - Caja master'];
const CONT_SHORT = {'MTA - Media Tina Alta':'MTA','MTB - Media Tina Baja':'MTB','CU - Contenedor Unico':'CU','TIR - Tina Roja':'TIR','CJM - Caja master':'CJM'};

/* ══ CONSTRUIR HTML DE UN TICKET TÉRMICO ══ */
function buildThermal(ruta, fecha, sucursal, folio, hora) {
  const prodRows = allData.filter(r=>r['Ruta']==ruta&&r['Fecha']&&r['Fecha'].toString().startsWith(fecha)&&r['Contenedor']);
  const eqRows   = allData.filter(r=>r['Ruta']==ruta&&r['Fecha']&&r['Fecha'].toString().startsWith(fecha)&&!r['Contenedor']&&r['Producto']);

  if (!prodRows.length && !eqRows.length) return null;

  // Agrupar por CATEGORÍA → dentro por CONTENEDOR
  const byCat = {};
  prodRows.forEach(r => {
    const cat = categorizar(r['Producto']||'');
    const cont = r['Contenedor'];
    if (!byCat[cat]) byCat[cat] = {};
    if (!byCat[cat][cont]) byCat[cat][cont] = [];
    byCat[cat][cont].push(r);
  });

  // Orden de categorías (las que aparecen)
  const catOrden = ['BOLLERÍA','SALADOS','TÍA ROSA','MARINELA','BIMBO DULCE','GALLETAS','OTROS'];

  let body = '';
  catOrden.forEach(cat => {
    if (!byCat[cat]) return;
    body += `<div class="th-sec-title">${cat}</div>`;
    CONT_ORDEN.forEach(cont => {
      const items = byCat[cat][cont];
      if (!items || !items.length) return;
      const cs = CONT_SHORT[cont] || cont;
      body += `<div style="font-size:9px;font-weight:bold;margin:2px 0 1px;text-decoration:underline;">${cs}</div>`;
      body += `<div class="th-col-headers"><span class="ch-prod">Producto</span><span class="ch-t">T</span><span class="ch-p">Pz</span></div>`;
      body += `<table class="th-table">`;
      items.forEach(r => {
        const t  = parseFloat(r['Tinas'])||0;
        const pz = parseFloat(r['Piezas'])||0;
        body += `<tr><td>${r['Producto']||''}</td><td>${t}</td><td>${pz}</td></tr>`;
      });
      body += `</table>`;
    });
  });

  // Equipo
  if (eqRows.length) {
    body += `<div class="th-equipo"><div class="th-equipo-title">EQUIPO</div>`;
    eqRows.forEach(r => {
      body += `<div class="th-eq-row"><span>${r['Producto']||''}</span><span>${parseFloat(r['Piezas'])||0}</span></div>`;
    });
    body += `</div>`;
  }

  const totalTinas = prodRows.reduce((s,r)=>s+(parseFloat(r['Tinas'])||0),0);
  const totalPzas  = prodRows.reduce((s,r)=>s+(parseFloat(r['Piezas'])||0),0);

  return `
    <div class="thermal-ticket">
      <div class="th-header">
        <div class="th-title">TICKET DE CARGA</div>
        <div class="th-sucursal">${sucursal}</div>
        <div class="th-meta"><span>${fmtF(fecha)}</span><span>${hora}</span></div>
        <div class="th-ruta">RUTA ${ruta} &nbsp; ${folio}</div>
      </div>
      <div class="th-body">${body}</div>
      <div class="th-footer">${prodRows.length} productos · ${totalTinas} tinas · ${totalPzas} pzas</div>
    </div>`;
}

/* ══ GENERAR TODOS ══ */
function generarTodos() {
  const fecha = document.getElementById('sel-fecha').value;
  const ini   = parseInt(document.getElementById('sel-ini').value);
  const fin   = parseInt(document.getElementById('sel-fin').value);
  const folio = document.getElementById('f-folio').value;
  const hora  = document.getElementById('f-hora').value;
  if (!fecha||!ini||!fin) return;

  const rutas = rutasEnRango(fecha, ini, fin);
  const grid  = document.getElementById('tickets-grid');
  grid.innerHTML = '';

  rutas.forEach(ruta => {
    // Sucursal de esta ruta
    const row = allData.find(r=>r['Ruta']==ruta&&r['Fecha']&&r['Fecha'].toString().startsWith(fecha)&&r['Agencia']);
    const sucursal = row ? (row['Agencia']||'').replace(/^\d+-/,'').trim() : '';

    const html = buildThermal(ruta, fecha, sucursal, folio, hora);
    if (!html) return;

    const card = document.createElement('div');
    card.className = 'ticket-card';
    card.innerHTML = html + `
      <div class="card-controls">
        <button class="btn-one" onclick="imprimirUno(this)">🖨 Imprimir esta ruta</button>
      </div>`;
    grid.appendChild(card);
  });

  document.getElementById('preview-title').style.display = 'block';
  document.getElementById('btn-print').style.display = 'block';

  if (!grid.children.length) {
    grid.innerHTML = '<div class="placeholder-big"><span>⚠</span>No se encontraron productos en ese rango</div>';
  }
}

/* ══ IMPRIMIR UNA SOLA TARJETA ══ */
